# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Loki (primary — direct HTTP API)
LOKI_URL=http://loki.internal:3100
LOKI_AUTH_TOKEN=

# Grafana (fallback only, optional)
GRAFANA_URL=http://grafana.internal:3000
GRAFANA_API_KEY=

# Repo paths (must be git-cloned on the same host as this service)
REPO_BITCOIN=/opt/repos/bitcoin-executor
REPO_EVM=/opt/repos/evm-executor
REPO_SOLANA=/opt/repos/solana-executor
REPO_SPARK=/opt/repos/spark-executor

# Bitcoin RPC
BITCOIN_RPC_URL=http://bitcoin-node.internal:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASS=

# EVM RPC
EVM_RPC_URL=https://your-evm-rpc-endpoint

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Spark RPC
SPARK_RPC_URL=http://spark-node.internal:8545

# Server
PORT=8000

# ── Investigation pipeline ──────────────────────────────────────────────────

# Max % deviation between filled_amount and expected amount before skipping (default 5%)
FILLED_AMOUNT_TOLERANCE_PCT=5.0

# URL that returns all solvers' available liquidity as JSON (no auth required)
LIQUIDITY_URL=https://api.garden.finance/liquidity

# Per-chain relayer wallet addresses (used in UserRedeemPending native balance check)
RELAYER_ADDRESS_BITCOIN=
RELAYER_ADDRESS_EVM=0x
RELAYER_ADDRESS_SOLANA=
RELAYER_ADDRESS_SPARK=

# Per-chain executor wallet addresses (used in SolverRedeemPending gas check)
EXECUTOR_ADDRESS_BITCOIN=
EXECUTOR_ADDRESS_EVM=0x
EXECUTOR_ADDRESS_SOLANA=
EXECUTOR_ADDRESS_SPARK=

# Minimum native balances before flagging as insufficient
# EVM: wei (default 0.01 ETH = 10_000_000_000_000_000)
MIN_EVM_GAS_BALANCE=10000000000000000
# Solana: lamports (default 0.01 SOL = 10_000_000)
MIN_SOLANA_GAS_BALANCE=10000000
# Bitcoin: satoshis (default 10k sats)
MIN_BITCOIN_GAS_BALANCE=10000
# Spark: wei (default 0.01 SPARK)
MIN_SPARK_GAS_BALANCE=10000000000000000
